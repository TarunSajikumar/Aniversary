# .env.example
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Currently this project has NO server-side secrets —
# it is a fully static HTML/CSS/JS site with no backend,
# no API keys, and no database connections.
#
# If you ever add a backend (e.g. for a contact form,
# analytics webhook, or media hosting), add its keys here:
# ─────────────────────────────────────────────────────────

# Example: e-mail service (e.g. SendGrid, Resend, Nodemailer)
# MAIL_API_KEY=your_mail_api_key_here

# Example: analytics ingestion key (server-side only)
# ANALYTICS_WRITE_KEY=your_analytics_key_here

# Example: storage / CDN upload token
# STORAGE_SECRET_TOKEN=your_storage_token_here
